public static void main(String[] args) {
      int[] arr = {4, 2, 7, 5, 2, 8, 7};
      int last=0;
      for(int i=0;i<arr.length;i++){
        int feq=0;
for(int j=0;j<arr.length;j++){
          if(arr[i]==arr[j]){
            feq++;
          }
        }
        if(feq==1){
          last=arr[i];
        }
      }
      System.out.println(last);
    }
