public static void main(String[] args) {
      int[] arr1 = {10,20,30};
      int[] arr2 = {40,50};
      int[] arr3 = new int[arr1.length+arr2.length];
      int index=0;
      for(int i=0;i<arr1.length;i++){
        arr3[index]=arr1[i];
        index++;
      }
      for(int i=0;i<arr2.length;i++){
        arr3[index]=arr2[i];
        index++;
      }
      for(int i=0;i<arr3.length;i++){
        System.out.print(arr3[i]+" ");
      }
    }
