public class Main {
    public static void main(String[] args) {
      int arr[]={10,2,5,8,2,5,12};
      for(int i=0;i<arr.length;i++){
        boolean duplicate=false;
        for(int j=0;j<i;j++){
          if(arr[i]==arr[j]){
            duplicate=true;
            break;
          }
        }
       if(!duplicate){
        System.out.print(arr[i]+" ");
       }
        
      }
    }
}
