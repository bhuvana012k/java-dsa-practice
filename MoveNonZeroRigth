public class Main {
    public static void main(String[] args) {
      int arr[]={5,0,0,2,1,0};
      int index=arr.length-1;
      for(int i=arr.length-1;i>=0;i--){
        if(arr[i]!=0){
          arr[index]=arr[i];
          index--;
        }
      }
      for(int i=index;i>=0;i--){
        arr[i]=0;
      }
      for(int i=0;i<arr.length;i++){
        System.out.print(arr[i]+" ");
      }
    }
    }

