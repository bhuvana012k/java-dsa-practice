public static void main(String[] args) {
      int[] arr1 = {5, 10, 15};
      int[] arr2 = {8, 15, 10};
      for(int i=0;i<arr1.length;i++){
        boolean found=false;
        for(int j=0;j<arr2.length;j++){
          if(arr1[i]==arr2[j]){
            found=true;
            break;
          }
        }
        if(found){
          System.out.print(arr1[i]+" ");
        }
      }
    }
