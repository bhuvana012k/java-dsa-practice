public class Main {
    public static void main(String[] args) {
      int arr[]={1,4,5,5,2,4,3};
      Scanner sc=new Scanner(System.in);
      System.out.println("Enter the element for freqency");
      int element=sc.nextInt();
      int freq=0;
      for(int i=0;i<arr.length;i++){
        if(arr[i]==element){
          freq++;
        }
      }
      System.out.println("freqency of element:"+freq);      
    }
}
