public class Main {
    public static void main(String[] args) {
      int arr[]={10,20,30,40,50};
      int search=40;//output=3;
      boolean found=false;
      for(int i=0;i<arr.length;i++){
        if(arr[i]==search){
          found=true;
          System.out.println("index:"+i);
          break;
        }
      }
      if(!found){
        System.out.println("element not founded");
      } 
    }
}
